// Prisma schema for the Energize Website Builder.
// Theme and status are stored as plain strings (not enums) so that adding a
// v2 theme stays purely additive and never requires a schema migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  wpSiteUrl              String
  wpUsername             String
  wpAppPasswordEncrypted String
  theme                  String
  brandKit               Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdBy              String

  builds            Build[]
  migrationProjects MigrationProject[]

  @@index([createdBy])
}

model MigrationProject {
  id                String         @id @default(cuid())
  crawlJobId        String?        @unique
  clientId          String?
  client            Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name              String
  sourceUrl         String?
  // draft | active | ready | deploying | complete | failed
  status            String         @default("draft")
  // source | cleanup | media | templates | plan | prepare | resolution | blogs | deploy | complete
  stage             String         @default("source")
  schemaVersion     Int            @default(1)
  sourcePages       Json           @default("[]")
  cleanedPages      Json           @default("[]")
  blogPosts         Json           @default("[]")
  blogDrafts        Json           @default("[]")
  assets            Json           @default("[]")
  selectedTemplates Json           @default("[]")
  mappings          Json           @default("[]")
  resolutions       Json           @default("[]")
  wizardWorkspace   Json           @default("{}")
  deployment        Json           @default("{}")
  lastError         String?
  createdBy         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  pagePlanItems     PagePlanItem[]

  @@index([clientId])
  @@index([createdBy])
  @@index([status])
  @@index([updatedAt])
}

model LayoutTemplate {
  id                String           @id @default(cuid())
  friendlyName      String
  category          String
  // ready | needs_setup | retired
  status            String           @default("needs_setup")
  activeRevisionId  String?          @unique
  activeRevision    LayoutRevision?  @relation("ActiveLayoutRevision", fields: [activeRevisionId], references: [id], onDelete: SetNull)
  thumbnail         Json             @default("{}")
  structuralSummary String
  createdBy         String
  retiredAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  revisions         LayoutRevision[] @relation("LayoutRevisions")

  @@index([createdBy])
  @@index([createdBy, status])
  @@index([createdBy, category])
  @@index([updatedAt])
}

model LayoutRevision {
  id                   String           @id @default(cuid())
  layoutTemplateId     String
  layoutTemplate       LayoutTemplate   @relation("LayoutRevisions", fields: [layoutTemplateId], references: [id], onDelete: Cascade)
  activeFor            LayoutTemplate[] @relation("ActiveLayoutRevision")
  pagePlanItems        PagePlanItem[]
  preparedDrafts       PreparedDraft[]
  version              Int
  sourceChecksum       String
  originalFilename     String
  analyzerVersion      String
  sanitizerVersion     String
  status               String
  sanitizedArtifact    Json
  semanticSlots        Json
  technicalFindings    Json
  sanitationReport     Json
  identityFingerprints Json
  createdAt            DateTime         @default(now())

  @@unique([layoutTemplateId, version])
  @@index([layoutTemplateId])
  @@index([sourceChecksum])
  @@index([status])
}

model PagePlanItem {
  id                 String           @id @default(cuid())
  migrationProjectId String
  migrationProject   MigrationProject @relation(fields: [migrationProjectId], references: [id], onDelete: Cascade)
  layoutRevisionId   String
  layoutRevision     LayoutRevision   @relation(fields: [layoutRevisionId], references: [id], onDelete: Restrict)
  position           Int
  pageName           String
  slug               String
  titleTag           String
  // home | standard | service | contact | custom
  pageType           String
  emptyDraftAllowed  Boolean          @default(true)
  // planned | matched | check | empty | ready | needs_attention
  status             String           @default("planned")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contentMatch       ContentMatch?
  preparedDrafts     PreparedDraft[]

  @@unique([migrationProjectId, slug])
  @@index([migrationProjectId, position])
  @@index([layoutRevisionId])
  @@index([status])
}

model ContentMatch {
  id                        String       @id @default(cuid())
  pagePlanItemId            String       @unique
  pagePlanItem              PagePlanItem @relation(fields: [pagePlanItemId], references: [id], onDelete: Cascade)
  sourcePageId              String?
  score                     Float        @default(0)
  signals                   Json         @default("[]")
  candidates                Json         @default("[]")
  // matched | check | empty
  status                    String
  confirmedByUser           Boolean      @default(false)
  normalizedContentRevision Int?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@index([status])
  @@index([sourcePageId])
}

model PreparedDraft {
  id                    String         @id @default(cuid())
  pagePlanItemId        String
  pagePlanItem          PagePlanItem   @relation(fields: [pagePlanItemId], references: [id], onDelete: Cascade)
  layoutRevisionId      String
  layoutRevision        LayoutRevision @relation(fields: [layoutRevisionId], references: [id], onDelete: Restrict)
  version               Int
  sourcePageId          String?
  sourceContentRevision Int?
  contentChecksum       String
  artifact              Json
  notes                 Json           @default("[]")
  residueReport         Json           @default("[]")
  // ready | needs_attention
  status                String
  adapterId             String
  adapterVersion        String
  createdAt             DateTime       @default(now())

  @@unique([pagePlanItemId, version])
  @@index([pagePlanItemId, createdAt])
  @@index([layoutRevisionId])
  @@index([status])
  @@index([contentChecksum])
}

model Build {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Array of deployed page records: { page, wpPageId, editUrl, status }.
  pagesDeployed Json?
  // pending | in_progress | success | partial | failed
  status        String    @default("pending")
  deployedAt    DateTime?
  deployedBy    String
  errorLog      String?
  createdAt     DateTime  @default(now())

  @@index([clientId])
  @@index([deployedBy])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  clientId  String?
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([clientId])
  @@index([timestamp])
}
