{
  "name": "energize-build-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:parser": "tsx src/lib/parser.test.ts",
    "typecheck": "tsc --noEmit",
