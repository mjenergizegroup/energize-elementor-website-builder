{
  "name": "energize-build-tool",
  "version": "4.1.0",
  "private": true,
  "scripts": {
    "test": "npm run test:parser && npm run test:deploy-schema && npm run test:build-wizard && npm run test:accessibility && npm run test:migration-cleanup && npm run test:migration-source-review && npm run test:migration-content-approval && npm run test:migration-workspace && npm run test:migration-media && npm run test:migration-content && npm run test:migration-dependencies && npm run test:migration-blogs && npm run test:migration-deploy && npm run test:template-import && npm run test:template-compile && npm run test:layout-sanitize && npm run test:layout-naming && npm run test:layout-preview && npm run test:page-plan && npm run test:content-matches && npm run test:prepared-drafts && npm run test:website-build && npm run test:upload-security && npm run test:wp-client && npm run verify:migration-security && npm run verify:atomic && npm run verify:bridge && npm run verify:injection",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:parser": "tsx src/lib/parser.test.ts",
    "test:deploy-schema": "tsx src/lib/deploy/schema.test.ts",
    "test:build-wizard": "tsx src/lib/build-wizard/flow.test.ts",
    "test:accessibility": "tsx src/lib/accessibility/audit.test.ts",
    "test:migration-cleanup": "tsx src/lib/migration/cleanup.test.ts",
    "test:migration-source-review": "tsx src/lib/migration/content/review.test.ts",
    "test:migration-content-approval": "tsx src/lib/migration/content/approval.test.ts",
    "test:migration-workspace": "tsx src/lib/migration/workspace.test.ts",
    "test:migration-media": "node --conditions=react-server --import tsx src/lib/migration/media/media.test.ts",
    "test:migration-content": "tsx src/lib/migration/content/content.test.ts",
    "test:migration-dependencies": "tsx src/lib/migration/dependencies.test.ts",
    "test:migration-blogs": "tsx src/lib/migration/blogs/blog.test.ts",
    "test:migration-deploy": "tsx src/lib/migration/deploy/deploy.test.ts",
    "test:template-import": "tsx src/lib/template-import/analyze.test.ts",
    "test:template-compile": "tsx src/lib/template-import/compiler/compiler.test.ts",
    "test:layout-sanitize": "tsx src/lib/layouts/sanitize.test.ts",
    "test:layout-naming": "tsx src/lib/layouts/naming.test.ts",
    "test:layout-preview": "tsx src/lib/layouts/preview.test.ts",
    "test:page-plan": "tsx src/lib/page-plan/page-plan.test.ts",
    "test:content-matches": "tsx src/lib/content-matches/matcher.test.ts",
    "test:prepared-drafts": "tsx src/lib/prepared-drafts/prepare.test.ts",
    "test:website-build": "tsx src/lib/website-builds/orchestrate.test.ts",
    "test:wp-client": "node --conditions=react-server --import tsx src/lib/wp/client.test.ts",
    "test:upload-security": "node --conditions=react-server --import tsx src/lib/security/uploads.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:injection": "tsx scripts/verify-injection.ts",
    "verify:atomic": "tsx src/lib/elementor/atomic/foundation.test.ts",
    "verify:bridge": "tsx scripts/verify-bridge-snippet.ts",
    "verify:migration-security": "tsx scripts/verify-migration-security.ts",
    "build:atomic-foundation": "tsx scripts/build-atomic-foundation.ts",
    "verify:parser": "tsx src/lib/parser.test.ts",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.4.3",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.42.2",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
